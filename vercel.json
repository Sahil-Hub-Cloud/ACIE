{
  "version": 2,
  "functions": {
    "api/*.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/login", "destination": "/api/login.js" },
    { "source": "/dashboard", "destination": "/api/dashboard.js" },
    { "source": "/copilot", "destination": "/api/copilot.js" },
    { "source": "/executive", "destination": "/api/executive.js" },
    { "source": "/war-room", "destination": "/api/war-room.js" },
    { "source": "/history", "destination": "/api/history.js" },
    { "source": "/api/github", "destination": "/api/github.js" },
    { "source": "/api/telemetry", "destination": "/api/telemetry.js" },
    { "source": "/api/copilot-brain", "destination": "/api/copilot-brain.js" }
  ]
}